@page "/dashboard"
@rendermode InteractiveServer
@using CurrencyExchange.Blazor.Services
@using CurrencyExchange.Core.DTOs.Auth
@using CurrencyExchange.Core.DTOs.Wallet
@using CurrencyExchange.Core.DTOs.Nbp
@inject ApiAuthService    AuthService
@inject ApiWalletService  WalletService
@inject ApiNbpService     NbpService
@inject NavigationManager Navigation

<PageTitle>Dashboard – Currency Exchange</PageTitle>

@if (_loading)
{
    <div class="d-flex justify-content-center align-items-center" style="height:60vh">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading…</span>
        </div>
    </div>
}
else
{
    <div class="container-fluid mt-4">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-0">Welcome back, <strong>@_profile?.FirstName</strong>! 👋</h2>
                <p class="text-muted mb-0">Currency Exchange Office</p>
            </div>
            <button class="btn btn-outline-danger" @onclick="Logout">Sign Out</button>
        </div>

        <!-- Wallet summary cards -->
        @if (_wallets.Count > 0)
        {
            <div class="row g-3 mb-4">
                @foreach (var w in _wallets)
                {
                    <div class="col-6 col-md-3">
                        <div class="card h-100 border-0 shadow-sm">
                            <div class="card-body text-center">
                                <p class="text-muted small mb-1">@w.CurrencyCode – @w.CurrencyName</p>
                                <h4 class="fw-bold @(w.CurrencyCode == "PLN" ? "text-primary" : "text-dark")">
                                    @w.Balance.ToString("N2")
                                </h4>
                                <span class="badge bg-light text-dark">@w.CurrencyCode</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-info mb-4">No wallets found. Create a wallet to get started.</div>
        }

        <!-- Quick actions -->
        <div class="row g-2 mb-4">
            <div class="col-6 col-md-3">
                <a href="/buy"           class="btn btn-success w-100 py-3">🟢 Buy Currency</a>
            </div>
            <div class="col-6 col-md-3">
                <a href="/sell"          class="btn btn-danger w-100 py-3">🔴 Sell Currency</a>
            </div>
            <div class="col-6 col-md-3">
                <a href="/transactions"  class="btn btn-outline-primary w-100 py-3">📋 Transactions</a>
            </div>
            <div class="col-6 col-md-3">
                <a href="/exchange-rates" class="btn btn-outline-secondary w-100 py-3">📈 Live Rates</a>
            </div>
        </div>

        <!-- Live NBP rates table -->
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>📊 Live Exchange Rates (NBP)</strong>
                <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshRates" disabled="@_ratesLoading">
                    @(_ratesLoading ? "Refreshing…" : "↻ Refresh")
                </button>
            </div>
            <div class="card-body p-0">
                @if (_ratesLoading)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
                        <span class="ms-2 text-muted">Loading rates…</span>
                    </div>
                }
                else if (_rates.Count == 0)
                {
                    <div class="alert alert-warning m-3">
                        NBP rates unavailable (markets may be closed or API is down).
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Currency</th>
                                    <th class="text-end">Bid (you sell at)</th>
                                    <th class="text-end">Ask (you buy at)</th>
                                    <th class="text-end">Mid</th>
                                    <th class="text-end">Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in _rates)
                                {
                                    <tr>
                                        <td><strong>@r.CurrencyCode</strong> <span class="text-muted small">@r.CurrencyName</span></td>
                                        <td class="text-end text-success">@r.MidRate.ToString("F4")</td>
                                        <td class="text-end text-danger">@(r.AskRate.HasValue ? r.AskRate.Value.ToString("F4") : r.MidRate.ToString("F4"))</td>
                                        <td class="text-end">@r.MidRate.ToString("F4")</td>
                                        <td class="text-end text-muted small">@r.EffectiveDate.ToString("yyyy-MM-dd")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

    </div>
}

@code {
    private UserProfileDto?          _profile;
    private List<WalletDto>          _wallets      = new();
    private List<NbpExchangeRateModel> _rates      = new();
    private bool _loading      = true;
    private bool _ratesLoading = false;
    private int? _domainUserId;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthService.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/login");
            return;
        }
        await AuthService.SetAuthHeaderAsync();

        var profileTask = AuthService.GetProfileAsync();
        var userIdTask  = AuthService.GetDomainUserIdAsync();
        var ratesTask   = NbpService.GetAllCurrentRatesAsync();

        await Task.WhenAll(profileTask, userIdTask, ratesTask);

        _profile       = profileTask.Result;
        _domainUserId  = userIdTask.Result;

        if (_domainUserId.HasValue)
            _wallets = await WalletService.GetByUserAsync(_domainUserId.Value);

        var ratesResp = ratesTask.Result;
        _rates = ratesResp?.Rates.ToList() ?? new();
        _loading = false;
    }

    private async Task RefreshRates()
    {
        _ratesLoading = true;
        var resp = await NbpService.GetAllCurrentRatesAsync();
        _rates        = resp?.Rates.ToList() ?? new();
        _ratesLoading = false;
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}

