<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
            <NotAuthorized>
                @{
                    var returnUrl = new Uri(Navigation.Uri).PathAndQuery;
                    Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(returnUrl)}", replace: true);
                }
            </NotAuthorized>
            <Authorizing>
                <div class="d-flex justify-content-center align-items-center" style="height:60vh">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Checking authentication…</span>
                    </div>
                </div>
            </Authorizing>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="typeof(Layout.MainLayout)">
            <div class="container mt-5 text-center">
                <h2>404 – Page Not Found</h2>
                <a href="/dashboard" class="btn btn-primary mt-3">Go to Dashboard</a>
            </div>
        </LayoutView>
    </NotFound>
</Router>

@inject NavigationManager Navigation
